<?xml version="1.0" encoding="utf-8"?>
<!-- Prod Heinz HTTPS -->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>

    <domain-config cleartextTrafficPermitted="false">
        <!-- si cliente usa HTTPS, va aqui -->
        <domain includeSubdomains="true">denario.net</domain>

        <trust-anchors>
            <!-- CA empaquetada para compatibilidad en Android antiguos -->
            <certificates src="@raw/denario_ca" />
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </domain-config>
    <domain-config cleartextTrafficPermitted="true">

        <!-- si cliente _NO_ usa HTTPS, va aqui -->
        <!-- tambien va aqui cualquier servidor de prueba -->
        <domain includeSubdomains="true">denariopremium.com</domain>
        <domain includeSubdomains="true">denariodemo.ddns.net</domain>
        <domain includeSubdomains="true">denarioelyaque.ddns.net</domain>
        <domain includeSubdomains="true">denarioislacoche.ddns.net</domain>
        <domain includeSubdomains="true">soportepremium.ddns.net</domain>

    </domain-config>
</network-security-config>
